# Copy to .env.local and fill in.
# The engine reads this key server-side only; it is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (auth + per-user data). The publishable key is safe for the browser;
# all data access is enforced by row-level security.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# UK Companies House (free official API) — register at
# developer.company-information.service.gov.uk, create an application,
# copy its REST API key here. Server-side only.
COMPANIES_HOUSE_API_KEY=

# Financial Modeling Prep (free tier: 250 calls/day) — register at
# financialmodelingprep.com. Responses are day-cached in .cache/ to stay
# well under the limits. Server-side only.
FMP_API_KEY=
