{
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "f1, f2, ..." },
          "target_section": {
            "type": "string",
            "enum": ["snapshot", "business_model", "ownership_control", "financial_picture", "capital_structure_health", "investment_angle", "what_we_dont_know", "cross_section"]
          },
          "target_estimate_id": { "type": "string", "description": "Estimate id the finding attacks; '' if section-level" },
          "issue_type": {
            "type": "string",
            "enum": ["weak_inference", "inflated_confidence", "deflated_confidence", "fact_dressing", "missing_unknown", "missing_cross_check", "internal_inconsistency", "indecisive", "legitimacy_concern", "fabricated_input", "missed_input", "other"]
          },
          "detail": { "type": "string", "description": "The specific problem, referencing the data" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "recommended_fix": { "type": "string", "description": "Concrete, actionable fix" }
        },
        "required": ["id", "target_section", "target_estimate_id", "issue_type", "detail", "severity", "recommended_fix"],
        "additionalProperties": false
      }
    },
    "overall_assessment": { "type": "string", "description": "2-4 sentences: is this dossier decision-grade after fixes?" }
  },
  "required": ["findings", "overall_assessment"],
  "additionalProperties": false
}
